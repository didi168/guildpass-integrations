# GuildPass Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# ── Mock / Demo Mode ──────────────────────────────────────────────────────────
# Set to "true" to use the in-memory mock API (no backend or wallet required).
# In mock mode, siweVerify() returns a fake token without checking the signature.
NEXT_PUBLIC_MOCK_MODE=true

# ── Live Mode ─────────────────────────────────────────────────────────────────
# Base URL of the running guildpass-core instance.
# Live mode calls /v1/* endpoints on this base URL, e.g.:
#   GET  http://localhost:4000/v1/session
#   POST http://localhost:4000/v1/auth/siwe/nonce
# Only required when NEXT_PUBLIC_MOCK_MODE is not "true".
NEXT_PUBLIC_CORE_API_URL=http://localhost:4000

# ── SIWE Authentication (Sign-In with Ethereum) ───────────────────────────────
# The domain field included in the EIP-4361 message. Should match the origin
# that the frontend is served from (used by the backend to prevent phishing).
# Defaults to window.location.host when unset.
NEXT_PUBLIC_SIWE_DOMAIN=localhost:3000

# The human-readable statement shown in the SIWE message that the user signs.
# Defaults to "Sign in to GuildPass Admin" when unset.
NEXT_PUBLIC_SIWE_STATEMENT="Sign in to GuildPass Admin"
