# GuildPass Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
#
# Configuration is validated at startup by lib/config.ts.
# Invalid values produce a clear error in development so broken
# configuration is caught immediately rather than at runtime.

# ── API Mode ──────────────────────────────────────────────────────────────────
# Controls whether the app uses the in-memory mock API or connects to a live
# guildpass-core backend.  The mode is derived from NEXT_PUBLIC_MOCK_MODE:
#
#   "true"  → mock mode (default for local development; no backend required)
#   unset / any other value → live mode
#
# Mock mode validates LESS — the API URL is optional and defaults to
# http://localhost:4000 for development convenience.
#
# Live mode validates MORE — NEXT_PUBLIC_CORE_API_URL is REQUIRED and must be
# a valid absolute URL.  The app will fail fast at startup if it is missing or
# malformed.
NEXT_PUBLIC_MOCK_MODE=true

# ── Live Mode ─────────────────────────────────────────────────────────────────
# Base URL of the running guildpass-core instance.
# Live mode calls /v1/* endpoints on this base URL, e.g.:
#   GET  http://localhost:4000/v1/session
#   POST http://localhost:4000/v1/auth/siwe/nonce
# Required when NEXT_PUBLIC_MOCK_MODE is not "true".
NEXT_PUBLIC_CORE_API_URL=http://localhost:4000

# ── SIWE Authentication (Sign-In with Ethereum) ───────────────────────────────
# The domain field included in the EIP-4361 message. Should match the origin
# that the frontend is served from (used by the backend to prevent phishing).
# Defaults to window.location.host when unset.
NEXT_PUBLIC_SIWE_DOMAIN=localhost:3000

# The human-readable statement shown in the SIWE message that the user signs.
# Defaults to "Sign in to GuildPass Admin" when unset.
NEXT_PUBLIC_SIWE_STATEMENT="Sign in to GuildPass Admin"

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Each flag controls whether a module is visible in navigation and accessible
# via its page route. Omitting a flag falls back to the default shown below.
#
# In mock/demo mode (NEXT_PUBLIC_MOCK_MODE=true) the flags for adminPolicies,
# events, and resources default to true so the full demo is visible locally.
# All other flags default to false in every environment.
#
# Recommended production defaults (copy these into your hosting platform's
# environment variable configuration, not into a committed file):
#
#   NEXT_PUBLIC_FEATURE_ADMIN_POLICIES=true   # enable when backend policies API is live
#   NEXT_PUBLIC_FEATURE_EVENTS=false          # enable when event management is ready
#   NEXT_PUBLIC_FEATURE_RESOURCES=true        # enable when gated resources are ready
#   NEXT_PUBLIC_FEATURE_ANALYTICS=false       # deferred — keep false until analytics module ships
#   NEXT_PUBLIC_FEATURE_GOVERNANCE=false      # deferred — keep false until governance ships

# Uncomment and set to "true" to enable a module, or "false" to force-disable it
# even in mock mode.
# NEXT_PUBLIC_FEATURE_ADMIN_POLICIES=true
# NEXT_PUBLIC_FEATURE_EVENTS=true
# NEXT_PUBLIC_FEATURE_RESOURCES=true
# NEXT_PUBLIC_FEATURE_ANALYTICS=false
# NEXT_PUBLIC_FEATURE_GOVERNANCE=false

# # Production Example
# NEXT_PUBLIC_MOCK_MODE=false
# NEXT_PUBLIC_CORE_API_URL=https://api.example.com
# NEXT_PUBLIC_SIWE_DOMAIN=app.example.com