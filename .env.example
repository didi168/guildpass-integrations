# GuildPass Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.
#
# Configuration is validated at startup by lib/config.ts.
# Invalid values produce a clear error in development so broken
# configuration is caught immediately rather than at runtime.

# ── API Mode ──────────────────────────────────────────────────────────────────
# Controls whether the app uses the in-memory mock API or connects to a live
# guildpass-core backend.  The mode is derived from NEXT_PUBLIC_MOCK_MODE:
#
#   "true"  → mock mode (default for local development; no backend required)
#   unset / any other value → live mode
#
# Mock mode validates LESS — the API URL is optional and defaults to
# http://localhost:4000 for development convenience.
#
# Live mode validates MORE — NEXT_PUBLIC_CORE_API_URL is REQUIRED and must be
# a valid absolute URL.  The app will fail fast at startup if it is missing or
# malformed.
NEXT_PUBLIC_MOCK_MODE=true

# Simulate a specific admin session state in mock mode.
# Accepted values:
#   "expired"         — siweVerify returns an already-expired token; admin
#                       mutations (assignRole/updatePolicy) throw a 401 to let
#                       you verify the re-auth banner works end-to-end.
#   "unauthenticated" — siweVerify always throws, simulating backend rejection.
#   (unset/default)   — normal mock behaviour (instant auth, 1-hour token).
# NEXT_PUBLIC_MOCK_SESSION_STATE=expired

# ── Live Mode ─────────────────────────────────────────────────────────────────
# Base URL of the running guildpass-core instance.
# Live mode calls /v1/* endpoints on this base URL, e.g.:
#   GET  http://localhost:4000/v1/session
#   POST http://localhost:4000/v1/auth/siwe/nonce
# Required when NEXT_PUBLIC_MOCK_MODE is not "true".
NEXT_PUBLIC_CORE_API_URL=http://localhost:4000

# Controls whether runtime API contract validation mismatches throw (false) or just log (true).
# Development mode throws by default; set this to true in production for resilience.
NEXT_PUBLIC_API_VALIDATION_LOG_ONLY=false

# API key for the server-side integration gateway.
# This value is used by the backend-facing route handlers and is never bundled
# into client-side code.
# The integration gateway is OPTIONAL. To use it, you must install the private
# @guildpass/integration-client package and set this API key.
INTEGRATION_API_KEY=

# ── SIWE Authentication (Sign-In with Ethereum) ───────────────────────────────
# The domain field included in the EIP-4361 message. Should match the origin
# that the frontend is served from (used by the backend to prevent phishing).
# Defaults to window.location.host when unset.
NEXT_PUBLIC_SIWE_DOMAIN=localhost:3000

# The human-readable statement shown in the SIWE message that the user signs.
# Defaults to "Sign in to GuildPass Admin" when unset.
# Must be a single line (no newlines or other control characters) and at most
# 200 characters — invalid values throw a ConfigError at startup.
NEXT_PUBLIC_SIWE_STATEMENT="Sign in to GuildPass Admin"


# ── Wallet / Chain Configuration ──────────────────────────────────────────────
# Comma-separated chain names offered to wagmi. Supported values:
#   mainnet, base, sepolia
# Defaults to all supported chains below when unset so mock mode works locally.
NEXT_PUBLIC_WALLET_CHAINS=mainnet,base,sepolia

# Optional browser-safe RPC URLs for each enabled chain. Leave blank to use
# wagmi/viem defaults. Do not place private RPC secrets here unless your RPC
# provider explicitly supports public browser keys.
# NEXT_PUBLIC_WALLET_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/public-key
# NEXT_PUBLIC_WALLET_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/public-key
# NEXT_PUBLIC_WALLET_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/public-key

# Comma-separated wallet connectors. Currently supported: injected.
# Unsupported values throw a ConfigError at startup. See the "Wallet
# connectors" section of README.md for how to add a new connector.
NEXT_PUBLIC_WALLET_CONNECTORS=injected

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Each flag controls whether a module is visible in navigation and accessible
# via its page route. Omitting a flag falls back to the default shown below.
#
# In mock/demo mode (NEXT_PUBLIC_MOCK_MODE=true) the flags for adminPolicies,
# adminSettings, events, and resources default to true so the full demo is
# visible locally. All other flags default to false in every environment.
#
# Recommended production defaults (copy these into your hosting platform's
# environment variable configuration, not into a committed file):
#
#   NEXT_PUBLIC_FEATURE_ADMIN_POLICIES=true   # enable when backend policies API is live
#   NEXT_PUBLIC_FEATURE_ADMIN_SETTINGS=false  # deferred — keep false until settings persistence ships
#   NEXT_PUBLIC_FEATURE_EVENTS=false          # enable when event management is ready
#   NEXT_PUBLIC_FEATURE_RESOURCES=true        # enable when gated resources are ready
#   NEXT_PUBLIC_FEATURE_ANALYTICS=false       # deferred — keep false until analytics module ships
#   NEXT_PUBLIC_FEATURE_GOVERNANCE=false      # deferred — keep false until governance ships
#   NEXT_PUBLIC_FEATURE_REWARDS=false         # deferred — keep false until reward engine ships
#   NEXT_PUBLIC_FEATURE_MULTI_COMMUNITY=false # deferred — nav stub only, no real multi-community logic yet
#   NEXT_PUBLIC_FEATURE_PROFILES=false        # deferred — keep false until rich profile customization (#254) ships
#   NEXT_PUBLIC_FEATURE_ANALYTICS_ROLLOUT_PCT=25 # optional canary percentage, 0-100

# Uncomment and set to "true" to enable a module, or "false" to force-disable it
# even in mock mode.
# NEXT_PUBLIC_FEATURE_ADMIN_POLICIES=true
# NEXT_PUBLIC_FEATURE_ADMIN_SETTINGS=true
# NEXT_PUBLIC_FEATURE_EVENTS=true
# NEXT_PUBLIC_FEATURE_RESOURCES=true
# NEXT_PUBLIC_FEATURE_ANALYTICS=false
# NEXT_PUBLIC_FEATURE_GOVERNANCE=false
# NEXT_PUBLIC_FEATURE_REWARDS=false
# NEXT_PUBLIC_FEATURE_MULTI_COMMUNITY=false
# NEXT_PUBLIC_FEATURE_PROFILES=false
# NEXT_PUBLIC_FEATURE_ANALYTICS_ROLLOUT_PCT=25

# # Production Example
# NEXT_PUBLIC_MOCK_MODE=false
# NEXT_PUBLIC_CORE_API_URL=https://api.example.com
# NEXT_PUBLIC_SIWE_DOMAIN=app.example.com

# ── Wallet RPC Configuration (Fallback-aware) ──────────────────────────────────
# Optional custom RPC URLs per chain. When set, the wallet transport uses wagmi's
# fallback composition: primary URL → public default. If the primary URL is
# unreachable at runtime, traffic transparently falls back to the public default
# and a non-blocking notice appears in the UI.
# Unset values fall back to the public default RPC for each chain.
# NEXT_PUBLIC_WALLET_RPC_MAINNET=https://eth.llamarpc.com
# NEXT_PUBLIC_WALLET_RPC_BASE=https://base.llamarpc.com
# NEXT_PUBLIC_WALLET_RPC_SEPOLIA=https://sepolia.llamarpc.com
