{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "allowJs": true,
    "noEmit": false,
    "outDir": "../test-dist",
    "rootDir": "..",
    "incremental": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "lib": ["dom", "dom.iterable", "es2022"],
    "types": ["node"]
  },
  "include": [
    "../lib/api/mappers.ts",
    "../lib/api/optimistic.ts",
    "../lib/api/types.ts",
    "../lib/api/access-decision.ts",
    "../lib/rate-limit.ts",
    "../lib/api/mock.ts",
    "../lib/wallet/address.ts",
    "../lib/wallet/config.ts",
    "../lib/wallet/connectors.ts",
    "../lib/wallet/siwe-session.ts",
    "../lib/config.ts",
    "../lib/features.ts",
    "../components/feature-gate.tsx",
    "../components/wallet/address-text.tsx",
    "../components/nav.tsx",
    "../app/[communitySlug]/admin/analytics/page.tsx",
    "../components/admin-guard.tsx",
    "../components/wallet/address-text.tsx",
    "../lib/wallet/siwe-context.ts",
    "../lib/query/*.ts",
    "../types/**/*.d.ts",
    "../scripts/sync-api-types.js",
    "./*.test.ts",
    "../lib/api/live.ts",
    "../lib/api/errors.ts",
    "../lib/api/validators.ts",
    "../lib/api/mock-storage.ts",
    "../lib/api/role-removal.ts",
    "../lib/validation/policy.ts"
  ]
}
